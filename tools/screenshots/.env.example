# Copy to .env and adjust as needed. Playwright doesn't auto-load .env —
# prefix commands with `npx dotenv-cli --` or set these in your shell rc.

# Where the PulseCoach addon's Next.js port is reachable.
#   - Addon on HAOS with port 3000/tcp enabled in the addon's
#     Network UI: http://homeassistant.local:3000
#   - Local `docker run -p 3000:3000 ghcr.io/askb/pulsecoach-addon-amd64:latest`
#     http://localhost:3000
BASE_URL=http://homeassistant.local:3000

# Output directory (relative to tools/screenshots/).
SCREENSHOT_DIR=screenshots

# "dark" or "light"
PULSECOACH_THEME=dark

