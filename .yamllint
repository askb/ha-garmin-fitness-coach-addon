extends: default

ignore: |
  .github/workflows/garmin-addon-daily-health.lock.yml
  .github/workflows/garmin-addon-review.lock.yml

rules:
  empty-lines:
    max-end: 1
  comments:
    min-spaces-from-content: 1
    level: error
  line-length:
    max: 120
    allow-non-breakable-words: true
