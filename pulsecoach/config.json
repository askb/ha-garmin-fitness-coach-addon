{
  "name": "PulseCoach",
  "version": "0.17.9",
  "slug": "pulsecoach",
  "image": "ghcr.io/askb/pulsecoach-addon-{arch}",
  "description": "AI-powered sport scientist — training analysis, coaching, and recovery optimization from your Garmin data",
  "url": "https://github.com/askb/ha-garmin-fitness-coach-addon",
  "arch": [
    "amd64",
    "aarch64"
  ],
  "homeassistant_api": true,
  "ingress": true,
  "ingress_port": 3000,
  "panel_icon": "mdi:heart-pulse",
  "panel_title": "PulseCoach",
  "init": false,
  "startup": "application",
  "timeout": 120,
  "map": [
    "addon_config:rw",
    "share:rw"
  ],
  "ports": {
    "3000/tcp": null
  },
  "options": {
    "garmin_email": "",
    "garmin_password": "",
    "strava_client_id": "",
    "strava_client_secret": "",
    "strava_refresh_token": "",
    "ai_backend": "none",
    "sync_interval_minutes": 60,
    "user_timezone": "UTC",
    "ha_events_enabled": true,
    "low_readiness_threshold": 50,
    "missed_session_grace_min": 360
  },
  "schema": {
    "garmin_email": "str?",
    "garmin_password": "password?",
    "strava_client_id": "str?",
    "strava_client_secret": "password?",
    "strava_refresh_token": "password?",
    "ai_backend": "list(ha_conversation|ollama|none)",
    "ollama_url": "str?",
    "sync_interval_minutes": "int(5,1440)?",
    "user_timezone": "str?",
    "ha_events_enabled": "bool",
    "low_readiness_threshold": "int(0,100)",
    "missed_session_grace_min": "int(0,1440)"
  },
  "environment": {
    "DATABASE_URL": "postgresql://postgres@127.0.0.1:5432/pulsecoach",
    "POSTGRES_URL": "postgresql://postgres@127.0.0.1:5432/pulsecoach",
    "DEV_BYPASS_AUTH": "true",
    "NODE_ENV": "production"
  }
}
